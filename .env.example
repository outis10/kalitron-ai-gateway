# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
AI_PROVIDER_IDENTITY=
AI_PROVIDER_RECEIPT=
OCR_PROVIDER_IDENTITY=ollama
OCR_PROVIDER_RECEIPT=
VISION_PROVIDER_IDENTITY=ollama
VISION_PROVIDER_RECEIPT=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=20
ANTHROPIC_MAX_RETRIES=1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=1

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL==qwen2.5vl:7b
# OLLAMA_MODEL=llama3.2-vision:11b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_RETRIES=1

# ── API Key Authentication ─────────────────────────────────────────────────────
# Comma-separated list of valid API keys
API_KEYS=key1,key2,key3

# ── Application ───────────────────────────────────────────────────────────────
PROJECT_NAME=AI Gateway
VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── Confidence Score Thresholds (0–100) ───────────────────────────────────────
SCORE_AUTO_APPROVE=95
SCORE_HUMAN_REVIEW=70

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
